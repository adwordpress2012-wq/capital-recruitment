# Optional: canonical origin for Open Graph / Twitter card images (no trailing slash).
# VITE_PUBLIC_SITE_URL=https://your-domain.example

# Supabase — public URL and anon key are exposed to the browser bundle (Vite).
# Never commit real keys; copy from Supabase Project Settings → API.
# Vercel / local: use either VITE_* or VITE_PUBLIC_* (both are read by the app).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_jwt_here

# Alternate public names (optional):
# VITE_PUBLIC_SUPABASE_URL=
# VITE_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never prefix with VITE_ or NEXT_PUBLIC_. Read only as SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_jwt_here

CAPITAL_ADMIN_PASSWORD=change_me_use_a_strong_password
CAPITAL_ADMIN_SESSION_SECRET=generate_a_long_random_string_for_cookie_signing

# Optional fallback if CAPITAL_ADMIN_SESSION_SECRET is unset:
# SUPABASE_JWT_SECRET=from_supabase_dashboard

# Optional Formspree (or compatible) POST endpoints — paste your form action URLs.
VITE_FORMSPREE_CANDIDATE_ACTION=
VITE_FORMSPREE_CONTACT_ACTION=
VITE_FORMSPREE_EMPLOYER_ACTION=
VITE_FORMSPREE_CANDIDATE_FILE_UPLOAD_ENABLED=
