# Optional Formspree (or compatible) POST endpoints — paste your form action URLs.
# Candidate applications should notify paul@capitalrecruitment.com.au (configure recipient in Formspree).
VITE_FORMSPREE_CANDIDATE_ACTION=
# Quick enquiry / general website contact (also set this in the Vercel project environment for production).
VITE_FORMSPREE_CONTACT_ACTION=https://formspree.io/f/mzdoqaov
VITE_FORMSPREE_EMPLOYER_ACTION=
# Set to true when the candidate Formspree form has file attachments enabled; until then the apply form stays text-only for submissions.
VITE_FORMSPREE_CANDIDATE_FILE_UPLOAD_ENABLED=
